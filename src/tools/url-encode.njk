<script>
const inputEl = document.getElementById('url-input');
const outputEl = document.getElementById('url-output');
const statusBar = document.getElementById('status-bar');

function setStatus(msg, type) {
  statusBar.textContent = msg;
  statusBar.className = 'status-bar ' + (type || '');
  if (type === 'error') { statusBar.style.background = '#3b1520'; statusBar.style.color = '#ff7b72'; }
  else if (type === 'success') { statusBar.style.background = '#0f2b1a'; statusBar.style.color = '#56d364'; }
  else { statusBar.style.background = ''; statusBar.style.color = ''; }
}

function encodeURL() {
  const val = inputEl.value;
  if (!val) { setStatus('No input', 'error'); return; }
  try {
    outputEl.value = encodeURI(val);
    setStatus('Encoded (URI)', 'success');
  } catch (e) { setStatus('Encoding failed: ' + e.message, 'error'); }
}

function encodeURLComponent() {
  const val = inputEl.value;
  if (!val) { setStatus('No input', 'error'); return; }
  try {
    outputEl.value = encodeURIComponent(val);
    setStatus('Encoded (Component)', 'success');
  } catch (e) { setStatus('Encoding failed: ' + e.message, 'error'); }
}

function decodeURL() {
  const val = inputEl.value.trim();
  if (!val) { setStatus('No input', 'error'); return; }
  try {
    outputEl.value = decodeURIComponent(val);
    setStatus('Decoded', 'success');
  } catch (e) { setStatus('Decoding failed: invalid percent encoding', 'error'); }
}

function clearAll() { inputEl.value = ''; outputEl.value = ''; setStatus(''); }
function swapValues() { const t = inputEl.value; inputEl.value = outputEl.value; outputEl.value = t; setStatus('Swapped'); }
async function pasteFromClipboard() { try { inputEl.value = await navigator.clipboard.readText(); setStatus('Pasted'); } catch { setStatus('Clipboard denied', 'error'); } }
function copyOutput() { if (!outputEl.value) { setStatus('Nothing to copy', 'error'); return; } navigator.clipboard.writeText(outputEl.value).then(() => setStatus('Copied', 'success')).catch(() => setStatus('Copy failed', 'error')); }
</script>
