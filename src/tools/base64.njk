<script>
const inputEl = document.getElementById('b64-input');
const outputEl = document.getElementById('b64-output');
const statusBar = document.getElementById('status-bar');

function setStatus(msg, type) {
  statusBar.textContent = msg;
  statusBar.className = 'status-bar ' + (type || '');
  if (type === 'error') {
    statusBar.style.background = '#3b1520';
    statusBar.style.color = '#ff7b72';
  } else if (type === 'success') {
    statusBar.style.background = '#0f2b1a';
    statusBar.style.color = '#56d364';
  } else {
    statusBar.style.background = '';
    statusBar.style.color = '';
  }
}

function encodeB64() {
  const val = inputEl.value;
  if (!val) { setStatus('No input', 'error'); return; }
  try {
    const encoded = btoa(unescape(encodeURIComponent(val)));
    outputEl.value = encoded;
    setStatus('Encoded — ' + encoded.length + ' chars', 'success');
  } catch (e) {
    setStatus('Encoding failed: ' + e.message, 'error');
  }
}

function decodeB64() {
  const val = inputEl.value.trim();
  if (!val) { setStatus('No input', 'error'); return; }
  try {
    const decoded = decodeURIComponent(escape(atob(val)));
    outputEl.value = decoded;
    setStatus('Decoded — ' + decoded.length + ' chars', 'success');
  } catch (e) {
    setStatus('Decoding failed: not valid Base64', 'error');
  }
}

function clearAll() {
  inputEl.value = '';
  outputEl.value = '';
  setStatus('');
}

function swapValues() {
  const tmp = inputEl.value;
  inputEl.value = outputEl.value;
  outputEl.value = tmp;
  setStatus('Swapped');
}

async function pasteFromClipboard() {
  try {
    const text = await navigator.clipboard.readText();
    inputEl.value = text;
    setStatus('Pasted from clipboard');
  } catch {
    setStatus('Clipboard access denied', 'error');
  }
}

function copyOutput() {
  if (!outputEl.value) { setStatus('Nothing to copy', 'error'); return; }
  navigator.clipboard.writeText(outputEl.value).then(() => {
    setStatus('Copied to clipboard', 'success');
  }).catch(() => {
    setStatus('Copy failed', 'error');
  });
}
</script>
