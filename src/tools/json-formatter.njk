<script>
const input = document.getElementById('json-input');
const output = document.getElementById('json-output');
const statusBar = document.getElementById('status-bar');

function setStatus(msg, type) {
  statusBar.textContent = msg;
  statusBar.className = 'status-bar ' + (type || '');
  if (type === 'error') {
    statusBar.style.background = '#3b1520';
    statusBar.style.color = '#ff7b72';
  } else if (type === 'success') {
    statusBar.style.background = '#0f2b1a';
    statusBar.style.color = '#56d364';
  } else {
    statusBar.style.background = '';
    statusBar.style.color = '';
  }
}

function syntaxHighlight(json) {
  json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  return json.replace(/("(\\u[a-fA-F0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function(match) {
    let cls = 'json-number';
    if (/^"/.test(match)) {
      if (/:$/.test(match)) {
        cls = 'json-key';
      } else {
        cls = 'json-string';
      }
    } else if (/true|false/.test(match)) {
      cls = 'json-boolean';
    } else if (/null/.test(match)) {
      cls = 'json-null';
    }
    return '<span class="' + cls + '">' + match + '</span>';
  });
}

function formatJSON() {
  const val = input.value.trim();
  if (!val) { setStatus('No input', 'error'); return; }
  try {
    const parsed = JSON.parse(val);
    const formatted = JSON.stringify(parsed, null, 2);
    output.innerHTML = '<pre>' + syntaxHighlight(formatted) + '</pre>';
    setStatus('Formatted successfully — ' + formatted.split('\n').length + ' lines', 'success');
  } catch (e) {
    output.innerHTML = '<pre class="error-output">' + escapeHtml(e.message) + '</pre>';
    setStatus('Invalid JSON: ' + e.message, 'error');
  }
}

function minifyJSON() {
  const val = input.value.trim();
  if (!val) { setStatus('No input', 'error'); return; }
  try {
    const parsed = JSON.parse(val);
    const minified = JSON.stringify(parsed);
    output.innerHTML = '<pre>' + escapeHtml(minified) + '</pre>';
    setStatus('Minified — ' + minified.length + ' bytes', 'success');
  } catch (e) {
    output.innerHTML = '<pre class="error-output">' + escapeHtml(e.message) + '</pre>';
    setStatus('Invalid JSON: ' + e.message, 'error');
  }
}

function validateJSON() {
  const val = input.value.trim();
  if (!val) { setStatus('No input', 'error'); return; }
  try {
    JSON.parse(val);
    output.innerHTML = '<pre class="valid-output">✓ Valid JSON</pre>';
    setStatus('Valid JSON', 'success');
  } catch (e) {
    output.innerHTML = '<pre class="error-output">✗ ' + escapeHtml(e.message) + '</pre>';
    setStatus('Invalid JSON: ' + e.message, 'error');
  }
}

function clearInput() {
  input.value = '';
  output.innerHTML = '';
  setStatus('');
}

async function pasteFromClipboard() {
  try {
    const text = await navigator.clipboard.readText();
    input.value = text;
    setStatus('Pasted from clipboard');
  } catch {
    setStatus('Clipboard access denied', 'error');
  }
}

function copyOutput() {
  const pre = output.querySelector('pre');
  if (!pre) { setStatus('Nothing to copy', 'error'); return; }
  navigator.clipboard.writeText(pre.textContent).then(() => {
    setStatus('Copied to clipboard', 'success');
  }).catch(() => {
    setStatus('Copy failed', 'error');
  });
}

function escapeHtml(str) {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

input.addEventListener('keydown', function(e) {
  if (e.key === 'Tab') {
    e.preventDefault();
    const start = this.selectionStart;
    const end = this.selectionEnd;
    this.value = this.value.substring(0, start) + '  ' + this.value.substring(end);
    this.selectionStart = this.selectionEnd = start + 2;
  }
});
</script>
