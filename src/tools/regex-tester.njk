<script>
const patternEl = document.getElementById('regex-pattern');
const flagsEl = document.getElementById('regex-flags');
const inputEl = document.getElementById('regex-input');
const highlightEl = document.getElementById('regex-highlight');
const groupsEl = document.getElementById('regex-groups');
const matchCountEl = document.getElementById('match-count');
const statusBar = document.getElementById('status-bar');

function setStatus(msg, type) {
  statusBar.textContent = msg;
  statusBar.className = 'status-bar ' + (type || '');
  if (type === 'error') { statusBar.style.background = '#3b1520'; statusBar.style.color = '#ff7b72'; }
  else if (type === 'success') { statusBar.style.background = '#0f2b1a'; statusBar.style.color = '#56d364'; }
  else { statusBar.style.background = ''; statusBar.style.color = ''; }
}

function escapeHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function testRegex() {
  const pattern = patternEl.value;
  const flags = flagsEl.value;
  const text = inputEl.value;

  if (!pattern) {
    highlightEl.innerHTML = '<pre>' + escapeHtml(text) + '</pre>';
    groupsEl.innerHTML = '<div class="no-match">Enter a pattern</div>';
    matchCountEl.textContent = '';
    setStatus('');
    return;
  }

  let regex;
  try {
    regex = new RegExp(pattern, flags);
    setStatus('');
  } catch (e) {
    highlightEl.innerHTML = '<pre>' + escapeHtml(text) + '</pre>';
    groupsEl.innerHTML = '<div class="regex-error">' + escapeHtml(e.message) + '</div>';
    matchCountEl.textContent = '';
    setStatus('Invalid regex: ' + e.message, 'error');
    return;
  }

  if (!text) {
    highlightEl.innerHTML = '';
    groupsEl.innerHTML = '<div class="no-match">Enter test string</div>';
    matchCountEl.textContent = '';
    return;
  }

  let matches = [];
  let groups = [];

  if (flags.includes('g')) {
    let m;
    while ((m = regex.exec(text)) !== null) {
      matches.push({ index: m.index, length: m[0].length, groups: m.slice(1) });
      if (m[0].length === 0) regex.lastIndex++;
      if (matches.length > 500) break;
    }
  } else {
    const m = regex.exec(text);
    if (m) matches.push({ index: m.index, length: m[0].length, groups: m.slice(1) });
  }

  matchCountEl.textContent = matches.length + ' match' + (matches.length !== 1 ? 'es' : '');

  // Build highlighted output
  let html = '';
  let lastIdx = 0;
  for (const match of matches) {
    html += escapeHtml(text.substring(lastIdx, match.index));
    html += '<mark class="regex-match">' + escapeHtml(text.substring(match.index, match.index + match.length)) + '</mark>';
    lastIdx = match.index + match.length;
  }
  html += escapeHtml(text.substring(lastIdx));
  highlightEl.innerHTML = '<pre>' + html + '</pre>';

  // Build groups
  if (matches.length === 0) {
    groupsEl.innerHTML = '<div class="no-match">No match</div>';
    setStatus('No matches', '');
  } else {
    let ghtml = '';
    matches.forEach((m, i) => {
      if (m.groups.length > 0) {
        ghtml += '<div class="group-match"><span class="group-label">Match ' + (i+1) + '</span>';
        m.groups.forEach((g, gi) => {
          ghtml += '<div class="group-entry"><span class="group-num">$' + (gi+1) + '</span> <code>' + (g !== undefined ? escapeHtml(g) : '<em>undefined</em>') + '</code></div>';
        });
        ghtml += '</div>';
      }
    });
    if (!ghtml) ghtml = '<div class="no-match">No capture groups</div>';
    groupsEl.innerHTML = ghtml;
    setStatus(matches.length + ' match' + (matches.length !== 1 ? 'es' : ''), 'success');
  }
}

function clearAll() { patternEl.value = ''; flagsEl.value = 'g'; inputEl.value = ''; highlightEl.innerHTML = ''; groupsEl.innerHTML = ''; matchCountEl.textContent = ''; setStatus(''); }
async function pasteFromClipboard() { try { inputEl.value = await navigator.clipboard.readText(); testRegex(); } catch { setStatus('Clipboard denied', 'error'); } }

patternEl.addEventListener('input', testRegex);
flagsEl.addEventListener('input', testRegex);
inputEl.addEventListener('input', testRegex);
</script>
